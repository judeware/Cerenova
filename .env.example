# Workload Identity Federation Configuration
# Google Cloud Project Number (REQUIRED)
GOOGLE_PROJECT_NUMBER=123456789012

# Service Account (must have Editor access to your Google Sheet)
GOOGLE_SERVICE_ACCOUNT_EMAIL=cerenova-sheets@YOUR_PROJECT_ID.iam.gserviceaccount.com

# Workload Identity Pool and Provider (must match Google Cloud configuration)
WORKLOAD_IDENTITY_POOL_ID=netlify-functions-pool
WORKLOAD_IDENTITY_PROVIDER_ID=netlify-provider

# Google Sheets Configuration
GOOGLE_SHEET_ID=your-google-sheet-id

# Netlify Site ID (REQUIRED - get from Netlify dashboard)
NETLIFY_SITE_ID=3e0bc499-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# RSA Private Key for JWT Signing (REQUIRED) - Base64 Encoded
# Encode your private.pem file to Base64 to avoid formatting issues:
# Linux/Mac: base64 -i private.pem -o private_base64.txt
# Windows: certutil -encode private.pem private_base64.txt
# Then copy the Base64 string (excluding header/footer lines) as the value
PRIVATE_KEY_PEM=YOUR_BASE64_ENCODED_PRIVATE_KEY_HERE

# Optional: Google Cloud Project ID (for logging)
# GOOGLE_CLOUD_PROJECT=your-project-id

# HubSpot Configuration
# Access Token for HubSpot API (Required for GP Referral System)
HUBSPOT_ACCESS_TOKEN=your-hubspot-private-app-access-token
